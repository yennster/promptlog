{
  "name": "@promptlog/daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx test/*.test.ts",
    "ax:snapshot": "tsx tools/ax-debug.ts snapshot",
    "ax:live": "tsx tools/ax-debug.ts live",
    "ax:record": "tsx tools/ax-debug.ts record",
    "ax:replay": "tsx tools/ax-debug.ts replay"
  },
  "dependencies": {
    "@promptlog/db": "workspace:*",
    "@promptlog/shared": "workspace:*",
    "better-sqlite3": "^11.7.0",
    "drizzle-orm": "^0.38.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
